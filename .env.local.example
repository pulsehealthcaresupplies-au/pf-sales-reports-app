# ============================================================================
# Sales Reports App - Local Development Environment Variables
# ============================================================================
# Copy this file to .env.local and update with your actual values
# NEVER commit .env.local files to version control
# Next.js automatically loads .env.local files

# ============================================================================
# Required: Backend Service URLs
# ============================================================================
# API Gateway URL (GraphQL, REST endpoints)
NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_API_GATEWAY_URL=http://localhost:8000  # Legacy alias

# Application URL (this frontend)
NEXT_PUBLIC_APP_URL=http://localhost:3004

# ============================================================================
# Optional: GraphQL Endpoints (auto-derived from API_URL if not set)
# ============================================================================
# GraphQL endpoint path (relative to API_URL)
# NEXT_PUBLIC_GRAPHQL_ENDPOINT=/graphql/sales-reports

# Auth GraphQL endpoint path (relative to API_URL)
# NEXT_PUBLIC_GRAPHQL_AUTH_ENDPOINT=/graphql/auth

# ============================================================================
# Optional: WebSocket Endpoints (auto-derived from API_URL if not set)
# ============================================================================
# WebSocket URL for GraphQL subscriptions (Sales Reports)
# NEXT_PUBLIC_WS_URL=ws://localhost:8000/graphql/sales-reports/ws

# WebSocket URL for Auth subscriptions
# NEXT_PUBLIC_WS_AUTH_URL=ws://localhost:8000/graphql/auth/ws

# WebSocket URL for Notifications
# NEXT_PUBLIC_WS_NOTIFICATIONS_URL=ws://localhost:8000/ws/notifications

# ============================================================================
# Required: Pulse Core / Media Service
# ============================================================================
# Pulse Core URL (for images, uploads, media)
# Required in production, optional in development (falls back to API_URL if not set)
NEXT_PUBLIC_PULSE_CORE_URL=http://localhost:8001

# Additional CSP image origins (comma-separated)
# NEXT_PUBLIC_CSP_IMG_ORIGINS=

# ============================================================================
# Optional: Feature Flags
# ============================================================================
# NEXT_PUBLIC_ENABLE_ANALYTICS=true
# NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
# NEXT_PUBLIC_ENABLE_ERROR_REPORTING=true
# NEXT_PUBLIC_ENABLE_PERFORMANCE_MONITORING=true
# NEXT_PUBLIC_ENABLE_DARK_MODE=true

# ============================================================================
# Optional: API Configuration
# ============================================================================
# NEXT_PUBLIC_API_TIMEOUT=10000
# NEXT_PUBLIC_API_RETRIES=3
# NEXT_PUBLIC_API_RETRY_DELAY=1000
# NEXT_PUBLIC_GRAPHQL_TIMEOUT=30000

# ============================================================================
# Environment Configuration
# ============================================================================
NODE_ENV=development
# NEXT_PUBLIC_DEPLOYMENT_MODE=development

# ============================================================================
# Application Port (Required for running the app)
# ============================================================================
PORT=3004

# ============================================================================
# Web Push (VAPID) – required for browser push notifications
# ============================================================================
# Generate when empty: npm run setup:vapid (see ../../docs/guides/VAPID_KEYS.md)
# NEVER commit VAPID_PRIVATE_KEY. Public key is safe in client bundle.
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# ============================================================================
# Next.js Server Actions (Production Only)
# ============================================================================
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=
